{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "hooks/session-start.sh",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "hooks/session-stop.sh",
        "cwd": ".",
        "timeoutSec": 5
      }
    ]
  }
}
